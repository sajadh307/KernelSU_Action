# ============================================
# Kernel Source (already has KernelSU + SuSFS)
# ============================================
KERNEL_SOURCE=https://github.com/prabhatkrmishra/kernel_motorola_fogos
KERNEL_SOURCE_BRANCH=15.0
KERNEL_CONFIG=vendor/fogos_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false

# ============================================
# KernelSU Settings (DISABLE auto patch because source already has it)
# ============================================
ENABLE_KERNELSU=false
KERNELSU_TAG=v0.9.5
APPLY_KSU_PATCH=false
ADD_KPROBES_CONFIG=false
ADD_OVERLAYFS_CONFIG=false
REMOVE_KSU_HOOKS=false

# Fixes for old linking/syntax errors
DISABLE_LTO=true
DISABLE_CC_WERROR=true

# ============================================
# Compiler (recommended for this kernel)
# ============================================
USE_CUSTOM_CLANG=false
CLANG_BRANCH=master-kernel-build-2022
CLANG_VERSION=r450784e
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
USE_CUSTOM_GCC_64=false
USE_CUSTOM_GCC_32=false

# ============================================
# AnyKernel3
# ============================================
USE_CUSTOM_ANYKERNEL3=false

# ============================================
# Extra
# ============================================
REMOVE_UNUSED_PACKAGES=true
EXTRA_CMDS:LD=ld.lld
